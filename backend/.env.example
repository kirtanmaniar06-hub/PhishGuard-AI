# ─── Application ──────────────────────────────────────────
APP_NAME="PhishGuard AI"
APP_VERSION="1.0.0"
APP_ENV="development"          # development | staging | production
DEBUG=true

# ─── Server ───────────────────────────────────────────────
HOST="0.0.0.0"
PORT=8000

# ─── Database ─────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://postgres:password@localhost:5432/phishguard_db"
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Security ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY="your-super-secret-key-change-in-production"
ALGORITHM="HS256"

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# ─── Admin Seed ───────────────────────────────────────────
FIRST_ADMIN_EMAIL="admin@phishguard.ai"
FIRST_ADMIN_PASSWORD="ChangeMe@2025!"
FIRST_ADMIN_USERNAME="superadmin"

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL="DEBUG"              # DEBUG | INFO | WARNING | ERROR
LOG_FILE="logs/phishguard.log"
